---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get Started">
<section class="pt-32 pb-20 px-6">
  <div class="max-w-lg mx-auto">
    <div class="text-sm text-cyan-300 font-mono mb-4">STEP 1 OF 2</div>
    <h1 class="text-3xl md:text-4xl font-bold mb-2">Almost There</h1>
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-white/10 bg-surface/50 text-sm text-muted mb-8">
      <span id="plan-dot" class="w-2 h-2 rounded-full bg-gradient-to-r from-purple-500 to-purple-700"></span>
      <span id="plan-label">Loading...</span>
    </div>

    <form id="signup-form" class="space-y-5 text-left">
      <div>
        <label class="block text-sm font-medium mb-2">Your Name <span class="text-purple-400">*</span></label>
        <input type="text" id="name" name="name" required 
          class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" 
          placeholder="Jane Smith">
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Email <span class="text-purple-400">*</span></label>
        <input type="email" id="email" name="email" required 
          class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" 
          placeholder="jane@example.com">
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Business Name <span class="text-muted font-normal">(optional)</span></label>
        <input type="text" id="business_name" name="business_name" 
          class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" 
          placeholder="Your Business LLC">
      </div>
      <div id="website-field">
        <label class="block text-sm font-medium mb-2" id="website-label">Website URL <span class="text-purple-400">*</span></label>
        <input type="text" id="website" name="website"
          class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" 
          placeholder="yoursite.com">
      </div>

      <!-- Full Management: existing site question -->
      <div id="full-mgmt-has-site" class="hidden space-y-5">
        <div class="border-t border-white/5 pt-5">
          <label class="block text-sm font-medium mb-3">Do you already have a website? <span class="text-purple-400">*</span></label>
          <div class="space-y-2">
            <label class="flex items-center gap-3 p-3 rounded-lg border border-white/10 bg-surface/50 cursor-pointer hover:border-purple-500/40 transition-colors">
              <input type="radio" name="has_site" value="yes" class="accent-purple-500">
              <span class="text-sm">Yes, I have an existing site to migrate</span>
            </label>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-white/10 bg-surface/50 cursor-pointer hover:border-purple-500/40 transition-colors">
              <input type="radio" name="has_site" value="no" class="accent-purple-500">
              <span class="text-sm">No, I need a site built from scratch</span>
            </label>
          </div>
        </div>

        <!-- Competitor sites (shown when "no" selected) -->
        <div id="competitor-sites" class="hidden space-y-4">
          <div class="border-t border-white/5 pt-5">
            <label class="block text-sm font-medium mb-2">List 3 competitor sites you like <span class="text-purple-400">*</span></label>
            <p class="text-xs text-muted mb-3">We'll pull design elements and features you love from these sites.</p>
            
            <div class="space-y-3">
              <input type="text" id="comp_site_1" name="comp_site_1" 
                class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" 
                placeholder="competitor1.com">
              <input type="text" id="comp_site_2" name="comp_site_2" 
                class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" 
                placeholder="competitor2.com">
              <input type="text" id="comp_site_3" name="comp_site_3" 
                class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" 
                placeholder="competitor3.com">
            </div>
          </div>
        </div>
      </div>

      <input type="hidden" name="plan" id="plan-input" value="seo_management">
      
      <button type="submit" class="btn-primary w-full text-lg py-4">
        Continue to Secure Payment →
      </button>
      <div class="flex items-center justify-center gap-2 text-xs text-muted">
        <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
        Secured by Stripe · Cancel anytime
      </div>
    </form>
    
    <div id="form-error" class="mt-4 text-sm text-red-400 hidden"></div>
  </div>
</section>
</Layout>

<script>
  // Parse plan from URL (SSG-compatible — runs client-side)
  const params = new URLSearchParams(window.location.search);
  const plan = params.get('plan') || 'seo_management';
  
  const plans = {
    seo_management: { label: 'SEO Management ($599/mo)', gradient: 'from-purple-500 to-purple-700', websiteRequired: true, isFullMgmt: false },
    full_management: { label: 'Full Management ($999/mo)', gradient: 'from-cyan-500 to-purple-500', websiteRequired: false, isFullMgmt: true },
  };
  
  const planInfo = plans[plan] || plans.seo_management;
  
  // Update hidden input
  document.getElementById('plan-input').value = plan;
  
  // Update UI
  document.getElementById('plan-label').textContent = planInfo.label;
  document.getElementById('plan-dot').className = `w-2 h-2 rounded-full bg-gradient-to-r ${planInfo.gradient}`;
  
  // Update website field
  const websiteLabel = document.getElementById('website-label');
  if (planInfo.websiteRequired) {
    websiteLabel.innerHTML = 'Website URL <span class="text-purple-400">*</span>';
  } else {
    websiteLabel.innerHTML = 'Website URL <span class="text-muted font-normal">(optional)</span>';
  }
  
  // Show Full Management fields
  if (planInfo.isFullMgmt) {
    document.getElementById('full-mgmt-has-site').classList.remove('hidden');
    
    // Toggle competitor sites based on radio selection
    document.querySelectorAll('input[name="has_site"]').forEach(radio => {
      radio.addEventListener('change', () => {
        const compSites = document.getElementById('competitor-sites');
        if (radio.value === 'no') {
          compSites.classList.remove('hidden');
        } else {
          compSites.classList.add('hidden');
        }
      });
    });
  }
  
  // Update page title
  document.title = `Get Started — ${planInfo.label}`;
  
  // Form submission
  const form = document.getElementById('signup-form');
  const error = document.getElementById('form-error');
  
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button');
    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Preparing checkout...';
    error.classList.add('hidden');
    
    let website = document.getElementById('website').value.trim();
    const businessName = document.getElementById('business_name').value.trim();
    const selectedPlan = document.getElementById('plan-input').value;
    
    // Auto-prepend https:// if no protocol
    if (website && !/^https?:\/\//i.test(website)) {
      website = 'https://' + website;
    }
    
    const data = {
      name: document.getElementById('name').value.trim(),
      email: document.getElementById('email').value.trim(),
      website,
      business_name: businessName,
      plan: selectedPlan,
    };
    
    // Full Management extra fields
    if (selectedPlan === 'full_management') {
      const hasSite = document.querySelector('input[name="has_site"]:checked');
      if (!hasSite) {
        error.textContent = 'Please select whether you have an existing website.';
        error.classList.remove('hidden');
        btn.disabled = false;
        btn.textContent = originalText;
        return;
      }
      data.has_site = hasSite.value;
      
      if (hasSite.value === 'no') {
        const comp1 = document.getElementById('comp_site_1').value.trim();
        const comp2 = document.getElementById('comp_site_2').value.trim();
        const comp3 = document.getElementById('comp_site_3').value.trim();
        
        const competitorSites = [comp1, comp2, comp3].filter(s => s.length > 0);
        if (competitorSites.length === 0) {
          error.textContent = 'Please list at least one competitor site you like.';
          error.classList.remove('hidden');
          btn.disabled = false;
          btn.textContent = originalText;
          return;
        }
        data.competitor_sites = competitorSites;
      }
    }
    
    if (!data.name || !data.email) {
      error.textContent = 'Please fill in your name and email.';
      error.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = originalText;
      return;
    }

    // Website required for SEO Management
    if (selectedPlan === 'seo_management' && !website) {
      error.textContent = 'Website URL is required for SEO Management.';
      error.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = originalText;
      return;
    }
    
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(data.email)) {
      error.textContent = 'Please enter a valid email address.';
      error.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = originalText;
      return;
    }
    
    try {
      const resp = await fetch('/api/create-checkout', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });
      
      const result = await resp.json();
      if (result.url) {
        window.location.href = result.url;
      } else {
        error.textContent = result.error || 'Something went wrong. Please try again.';
        error.classList.remove('hidden');
      }
    } catch (err) {
      error.textContent = 'Connection error. Please check your internet and try again.';
      error.classList.remove('hidden');
    }
    
    btn.disabled = false;
    btn.textContent = originalText;
  });
</script>
