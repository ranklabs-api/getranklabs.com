---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Thank You — Rank Labs">

<section class="pt-32 pb-20 px-6">
  <div class="max-w-xl mx-auto text-center">
    <div class="text-5xl mb-6">🧪</div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4">
      Welcome to <span class="gradient-text">Rank Labs</span>
    </h1>
    <p class="text-lg text-muted mb-8">
      Your payment is processing. You'll receive a confirmation email shortly, and we'll reach out within 24 hours to kick things off.
    </p>

    <div class="gradient-border rounded-xl p-6 mb-8 text-left">
      <h2 class="font-semibold text-sm text-cyan-300 mb-3">What happens next</h2>
      <ol class="space-y-3 text-sm text-muted">
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold shrink-0">1.</span>
          Check your inbox for a confirmation email (if you don't see it, check spam)
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold shrink-0">2.</span>
          We'll reach out within 24 hours to gather your site details or existing site credentials
        </li>
        <li class="flex gap-3">
          <span class="text-purple-400 font-bold shrink-0">3.</span>
          The formula activates — your first SEO audit arrives within 24 hours of site connection
        </li>
      </ol>
    </div>

    <p class="text-sm text-muted">
      Questions? Reach us at <a href="mailto:hello@getranklabs.com" class="text-purple-400 hover:text-purple-300">hello@getranklabs.com</a>
    </p>
  </div>
</section>

</Layout>
