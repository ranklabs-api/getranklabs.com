---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Services — Rank Labs">

<section class="pt-32 pb-20 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-sm text-cyan-300 font-mono mb-4">WHAT'S IN THE LAB</div>
    <h1 class="text-4xl md:text-5xl font-bold mb-6">Our <span class="gradient-text">Formula</span></h1>
    <p class="text-lg text-muted mb-16 max-w-2xl">
      Two tiers, one mission: make your site impossible to ignore. Every plan is month-to-month — no contracts, no surprises.
    </p>

    <!-- SEO Management -->
    <div class="border-t border-white/5 pt-12 mb-16">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
        <div>
          <div class="text-xs text-purple-300 font-mono mb-2">$599/MO</div>
          <h2 class="text-2xl font-bold">SEO Management</h2>
          <p class="text-muted mt-2 max-w-xl">Weekly audits, rankings, and strategy delivered to your inbox. You keep your existing team and site — we provide the intelligence.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div>
          <h3 class="font-semibold text-sm text-cyan-300 mb-3">Audits & Monitoring</h3>
          <ul class="space-y-2">
            {['Weekly automated SEO audits (100+ checks)', 'Broken link detection & repair', 'Missing meta tags & descriptions', 'Page speed & Core Web Vitals', 'Mobile responsiveness check', 'Structured data verification', 'Sitemap & canonical strategy'].map(b => (
              <li class="flex items-center gap-3 text-sm text-muted"><span class="w-1.5 h-1.5 bg-purple-500 rounded-full shrink-0"></span>{b}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-sm text-cyan-300 mb-3">Rankings & Strategy</h3>
          <ul class="space-y-2">
            {['Keyword position tracking', 'Competitor gap analysis', 'Backlink profile monitoring', 'Monthly ranking reports', 'Content strategy recommendations', 'Technical SEO issue detection', 'CTA & conversion recommendations'].map(b => (
              <li class="flex items-center gap-3 text-sm text-muted"><span class="w-1.5 h-1.5 bg-purple-500 rounded-full shrink-0"></span>{b}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-sm text-cyan-300 mb-3">Content & Structure</h3>
          <ul class="space-y-2">
            {['Content gap analysis', 'Topic cluster planning', 'Seasonal content calendar', 'Internal link optimization', 'FAQ schema implementation', 'Local schema markup', '3/6/12 month performance benchmarks'].map(b => (
              <li class="flex items-center gap-3 text-sm text-muted"><span class="w-1.5 h-1.5 bg-purple-500 rounded-full shrink-0"></span>{b}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Full Management -->
    <div class="border-t border-white/5 pt-12 mb-16">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
        <div>
          <div class="text-xs text-cyan-300 font-mono mb-2">$999/MO</div>
          <h2 class="text-2xl font-bold">Full Management</h2>
          <p class="text-muted mt-2 max-w-xl">Everything in SEO Management, plus we build, host, and maintain your site. You focus on your business — we handle the rest.</p>
          <p class="text-xs text-muted mt-2"><span class="text-white font-medium">+ one-time site build or $1,000 migration</span> for new or existing sites</p>
        </div>
        <span class="text-xs px-3 py-1 bg-purple-500/20 border border-purple-500/40 rounded-full text-purple-300 font-semibold shrink-0 h-fit">MOST POPULAR</span>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <div>
          <h3 class="font-semibold text-sm text-cyan-300 mb-3">Site Hosting & Management</h3>
          <ul class="space-y-2">
            {['Global edge hosting (330+ cities)', 'Automatic SSL certificates', 'Global CDN & DDoS protection', 'Unlimited site edits & updates', 'One-click rollbacks & daily backups', 'Site fixes on demand'].map(b => (
              <li class="flex items-center gap-3 text-sm text-muted"><span class="w-1.5 h-1.5 bg-purple-500 rounded-full shrink-0"></span>{b}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-sm text-cyan-300 mb-3">Content Creation</h3>
          <ul class="space-y-2">
            {['Weekly blog content (researched & written)', 'Keyword & competitor research per post', '800+ word SEO-optimized drafts', 'Easy approval workflow', 'Scheduled publishing & content calendar', 'Service-area landing pages'].map(b => (
              <li class="flex items-center gap-3 text-sm text-muted"><span class="w-1.5 h-1.5 bg-purple-500 rounded-full shrink-0"></span>{b}</li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold text-sm text-cyan-300 mb-3">Local SEO & Listings</h3>
          <ul class="space-y-2">
            {['Google Business Profile optimization', 'Business listing management', 'Local schema markup', 'Service-area page strategy', 'City + service keyword targeting', 'Review monitoring & response'].map(b => (
              <li class="flex items-center gap-3 text-sm text-muted"><span class="w-1.5 h-1.5 bg-purple-500 rounded-full shrink-0"></span>{b}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <!-- Site Builds -->
    <div class="border-t border-white/5 pt-12">
      <div class="text-xs text-cyan-300 font-mono mb-2">ONE-TIME</div>
      <h2 class="text-2xl font-bold mb-2">Site Builds & Migration</h2>
      <p class="text-muted mb-8 max-w-xl">Custom sites built on a global edge network — fast, modern, zero ongoing dev costs. Already have a site? We'll migrate it seamlessly. Every build includes:</p>
      <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2 mb-8">
        {['Responsive design (mobile + desktop)', 'SEO-optimized from day one', 'SSL & global CDN included', 'Easy content management', '1 round of revisions included'].map(b => (
          <li class="flex items-center gap-3 text-sm text-muted"><span class="w-1.5 h-1.5 bg-purple-500 rounded-full shrink-0"></span>{b}</li>
        ))}
      </ul>
      <div class="space-y-3">
        {[
          { pages: 'Landing Page — $1,250', desc: 'Single-page site. Perfect for product launches, lead gen, or a simple web presence.' },
          { pages: 'Up to 5 Pages — $2,500', desc: 'Home, About, Services, Blog, Contact. The full business stack.' },
          { pages: 'Site Migration — $1,000', desc: 'Moving from Wix, Squarespace, WordPress? We handle DNS, content, and redirects with zero downtime.' },
          { pages: '6+ Pages — Custom Quote', desc: "Complex sites, e-commerce, dashboards, or anything custom. Let's talk." },
        ].map((tier) => (
          <div class="gradient-border rounded-xl p-4">
            <div class="font-semibold text-sm">{tier.pages}</div>
            <div class="text-xs text-muted mt-1">{tier.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

</Layout>
