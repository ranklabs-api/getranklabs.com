---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Rank Labs">

<section class="pt-32 pb-20 px-6">
  <div class="max-w-xl mx-auto text-center">
    <div class="text-sm text-cyan-300 font-mono mb-4">GET IN TOUCH</div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Let's <span class="gradient-text">Talk</span></h1>
    <p class="text-lg text-muted mb-12">
      Got a question? Want a free SEO audit? Just want to say hi? Drop us a message.
    </p>

    <form id="contact-form" class="text-left space-y-5">
      <div>
        <label class="block text-sm font-medium mb-2">Name *</label>
        <input type="text" id="name" name="name" required class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="Your name">
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Email *</label>
        <input type="email" id="email" name="email" required class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="you@example.com">
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Website (optional)</label>
        <input type="url" id="url" name="url" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="https://yoursite.com">
      </div>
      <div>
        <label class="block text-sm font-medium mb-2">Message</label>
        <textarea id="message" name="message" rows="4" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors resize-none" placeholder="Tell us about your project, goals, or just say hi..."></textarea>
      </div>

      <button type="submit" class="btn-primary w-full">Send Message →</button>
      <p class="text-xs text-muted text-center">No spam. No sales calls. Just good conversation.</p>
    </form>

    <div id="form-status" class="mt-4 text-sm hidden"></div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    const btn = form.querySelector('button');
    btn.disabled = true;
    btn.textContent = 'Sending...';

    const data = {
      name: document.getElementById('name').value.trim(),
      email: document.getElementById('email').value.trim(),
      url: document.getElementById('url').value.trim(),
      notes: document.getElementById('message').value.trim(),
      type: 'contact',
      submittedAt: new Date().toISOString(),
    };

    if (!data.name || !data.email) {
      status.className = 'mt-4 text-sm text-red-400';
      status.textContent = 'Please fill in your name and email.';
      status.classList.remove('hidden');
      btn.disabled = false;
      btn.textContent = 'Send Message \u2192';
      return;
    }

    try {
      const resp = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (resp.ok) {
        status.className = 'mt-4 text-sm text-green-400';
        status.textContent = 'Message sent! We\'ll get back to you soon.';
        form.reset();
      } else {
        const err = await resp.json().catch(() => ({}));
        status.className = 'mt-4 text-sm text-red-400';
        status.textContent = err.error || 'Something went wrong. Please try again.';
      }
    } catch (err) {
      status.className = 'mt-4 text-sm text-red-400';
      status.textContent = 'Unable to send. Please email hello@getranklabs.com';
    }

    status.classList.remove('hidden');
    btn.disabled = false;
    btn.textContent = 'Send Message \u2192';
  });
</script>

</Layout>
