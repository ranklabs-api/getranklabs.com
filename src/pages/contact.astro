---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Rank Labs">

<section class="pt-32 pb-20 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <div class="text-sm text-cyan-300 font-mono mb-4">GET STARTED</div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Get the <span class="gradient-text">Formula</span></h1>
    <p class="text-lg text-muted mb-12">
      Tell us about your site and we'll deliver a comprehensive SEO audit within 24 hours — free. No strings attached.
    </p>

    <form id="contact-form" class="text-left space-y-6" onsubmit="event.preventDefault(); handleSubmit()">
      <!-- Site status toggle -->
      <div>
        <label class="block text-sm font-medium mb-3">Do you already have a website?</label>
        <div class="grid grid-cols-2 gap-3">
          <button type="button" id="has-site-yes" class="px-4 py-3 bg-surface border border-cyan-500/50 rounded-lg text-sm font-medium text-cyan-300 hover:border-cyan-400 transition-colors" onclick="toggleSiteMode(true)">✅ Yes, I have a site</button>
          <button type="button" id="has-site-no" class="px-4 py-3 bg-surface border border-white/10 rounded-lg text-sm font-medium text-muted hover:border-white/20 transition-colors" onclick="toggleSiteMode(false)">🔨 I need a site built</button>
        </div>
      </div>

      <!-- Existing site fields -->
      <div id="existing-site-fields">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-2">Name</label>
            <input type="text" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="John Smith" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Email</label>
            <input type="email" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="john@company.com" />
          </div>
        </div>
        <div class="mt-4">
          <label class="block text-sm font-medium mb-2">Website URL</label>
          <input type="url" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="https://yoursite.com" />
        </div>
      </div>

      <!-- New site fields (hidden by default) -->
      <div id="new-site-fields" class="hidden space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium mb-2">Name</label>
            <input type="text" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="John Smith" />
          </div>
          <div>
            <label class="block text-sm font-medium mb-2">Email</label>
            <input type="email" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="john@company.com" />
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">What kind of site do you need?</label>
          <input type="text" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="e.g. E-commerce store, SaaS landing page, portfolio, blog..." />
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">3 sites you'd like to model yours after</label>
          <div class="space-y-2">
            <input type="url" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="https://example.com — site #1" />
            <input type="url" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="https://example.com — site #2" />
            <input type="url" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="https://example.com — site #3" />
          </div>
          <p class="text-xs text-muted mt-2">Don't overthink it — just share sites whose vibe you like.</p>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">Pages you need</label>
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
            {['Home','About','Services','Blog','Contact','Pricing','FAQ','Gallery','Testimonials','Other'].map(page => (
              <label class="flex items-center gap-2 text-sm text-muted cursor-pointer">
                <input type="checkbox" class="accent-purple-500" /> {page}
              </label>
            ))}
          </div>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">Any content or branding you already have?</label>
          <textarea rows="3" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors resize-none" placeholder="Logo, brand colors, existing copy, photos, style guide... anything helps!"></textarea>
        </div>

        <div>
          <label class="block text-sm font-medium mb-2">Timeline & budget</label>
          <textarea rows="2" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors resize-none" placeholder="When do you need it live? What's your rough budget range?"></textarea>
        </div>
      </div>

      <!-- Shared field -->
      <div class="mt-4">
        <label class="block text-sm font-medium mb-2">Anything else we should know?</label>
        <textarea rows="3" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors resize-none" placeholder="Goals, challenges, competitors, timeline..."></textarea>
      </div>

      <button type="submit" class="btn-primary w-full">Submit →</button>
      <p class="text-xs text-muted text-center">No spam. No sales calls. Just your free audit.</p>
    </form>
  </div>
</section>

<script>
  function toggleSiteMode(hasSite) {
    const yesBtn = document.getElementById('has-site-yes');
    const noBtn = document.getElementById('has-site-no');
    const existingFields = document.getElementById('existing-site-fields');
    const newSiteFields = document.getElementById('new-site-fields');

    if (hasSite) {
      yesBtn.className = 'px-4 py-3 bg-surface border border-cyan-500/50 rounded-lg text-sm font-medium text-cyan-300 hover:border-cyan-400 transition-colors';
      noBtn.className = 'px-4 py-3 bg-surface border border-white/10 rounded-lg text-sm font-medium text-muted hover:border-white/20 transition-colors';
      existingFields.classList.remove('hidden');
      newSiteFields.classList.add('hidden');
    } else {
      noBtn.className = 'px-4 py-3 bg-surface border border-cyan-500/50 rounded-lg text-sm font-medium text-cyan-300 hover:border-cyan-400 transition-colors';
      yesBtn.className = 'px-4 py-3 bg-surface border border-white/10 rounded-lg text-sm font-medium text-muted hover:border-white/20 transition-colors';
      existingFields.classList.add('hidden');
      newSiteFields.classList.remove('hidden');
    }
  }

  function handleSubmit() {
    alert("Thanks! We'll review your request and get back to you within 24 hours.");
  }
</script>

</Layout>
