---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Rank Labs">

<section class="pt-32 pb-20 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <div class="text-sm text-cyan-300 font-mono mb-4">GET STARTED</div>
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Get the <span class="gradient-text">Formula</span></h1>
    <p class="text-lg text-muted mb-12">
      Tell us about your site and we'll deliver a comprehensive SEO audit within 24 hours — free. No strings attached.
    </p>

    <form class="text-left space-y-6" onsubmit="event.preventDefault(); alert('Thanks! We\'ll be in touch within 24 hours.')">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium mb-2">Name</label>
          <input type="text" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="John Smith" />
        </div>
        <div>
          <label class="block text-sm font-medium mb-2">Email</label>
          <input type="email" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="john@company.com" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">Website URL</label>
        <input type="url" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors" placeholder="https://yoursite.com" />
      </div>

      <div>
        <label class="block text-sm font-medium mb-2">What are you looking to improve?</label>
        <textarea rows="4" class="w-full bg-surface border border-white/10 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-purple-500 transition-colors resize-none" placeholder="Tell us about your goals, challenges, or current SEO situation..."></textarea>
      </div>

      <button type="submit" class="btn-primary w-full">Submit →</button>
      <p class="text-xs text-muted text-center">No spam. No sales calls. Just your free audit.</p>
    </form>
  </div>
</section>

</Layout>
