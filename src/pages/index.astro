---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- Hero -->
<section class="relative pt-32 pb-20 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-cyan-500/10 via-purple-500/5 to-transparent"></div>
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-cyan-500/10 rounded-full blur-3xl"></div>

  <div class="max-w-4xl mx-auto text-center relative">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 text-sm text-cyan-300 mb-8">
      <span class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse"></span>
      AI Search Optimization — For ChatGPT, Claude, Gemini & Perplexity
    </div>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-none mb-6">
      Get Found on ChatGPT,<br/>
      <span class="gradient-text">Claude, Gemini & Perplexity.</span>
    </h1>

    <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-10">
      <span class="gradient-text font-bold">Cited by AI. Ranked by Google.</span> 
      Rank Labs runs both from one playbook, so your business shows up everywhere customers are looking.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact" class="btn-primary text-lg">Get Your Free AI Visibility Report →</a>
      <a href="/#how-it-works" class="btn-secondary text-lg">See How It Works</a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-4 gap-8 mt-20 pt-12 border-t border-white/5">
      <div>
        <div class="text-3xl font-bold gradient-text">4</div>
        <div class="text-sm text-muted mt-1">AI Engines Covered</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">69%</div>
        <div class="text-sm text-muted mt-1">Changed Vendors Via AI</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">51%</div>
        <div class="text-sm text-muted mt-1">Buyers Start On AI First</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">From $599</div>
        <div class="text-sm text-muted mt-1">Per Month</div>
      </div>
    </div>
  </div>
</section>

<!-- What We Do — AI-First Services -->
<section id="services" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <div class="text-sm text-cyan-300 font-mono mb-4">WHAT WE DO</div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Be the Answer When AI Gets Asked</h2>
      <p class="text-muted max-w-xl mx-auto">Four pillars. Every AI engine. One platform.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      {[
        {
          icon: '🔍',
          title: 'AI Visibility Audit',
          desc: 'We ask ChatGPT, Claude, Gemini, and Perplexity about your industry — and show you exactly where your business is missing, misrepresented, or invisible. One report, four engines, zero jargon.',
        },
        {
          icon: '⚡',
          title: 'AI Optimization',
          desc: 'We rebuild your content so AI models can read it, trust it, and quote it — turning your website into a source AI actually recommends to its users.',
        },
        {
          icon: '🔗',
          title: 'Citation & Mention Building',
          desc: 'We get your business referenced across the sites, reviews, and sources AI models pull answers from, so you show up more often, in more places.',
        },
        {
          icon: '📈',
          title: 'AI Rank Tracking & Reporting',
          desc: 'Ongoing monitoring of how your brand shows up across every major AI assistant — with clear monthly reports on where you stand and what\'s changing.',
        },
      ].map((service) => (
        <div class="gradient-border rounded-xl p-6 hover:bg-surface-light/50 transition-colors">
          <div class="text-3xl mb-4">{service.icon}</div>
          <h3 class="font-semibold text-lg mb-2">{service.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{service.desc}</p>
        </div>
      ))}
    </div>

    <p class="text-center text-sm text-muted">
      Plus: weekly SEO audits, keyword tracking, schema markup, backlink monitoring, content strategy, and full site management — <em>because stronger Google rankings come built-in when you optimize for AI.</em>
    </p>
  </div>
</section>

<!-- The AI Engines -->
<section id="geo" class="py-24 px-6 bg-surface/30 relative overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-r from-cyan-500/5 via-purple-500/5 to-cyan-500/5"></div>
  <div class="max-w-6xl mx-auto relative">
    <div class="text-center mb-16">
      <div class="text-sm text-cyan-300 font-mono mb-4">THE PLATFORMS</div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">
        We Optimize You for Every<br/>
        <span class="gradient-text">AI Engine That Matters.</span>
      </h2>
      <p class="text-muted max-w-2xl mx-auto">
        More people are asking ChatGPT, Claude, Gemini, and Perplexity for recommendations than ever before — 
        and each engine looks for different signals. Here's exactly how we make you visible on each one.
      </p>
    </div>

    <!-- Per-Engine Checklist -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-16">
      <!-- ChatGPT -->
      <div class="gradient-border rounded-2xl p-6 md:p-8 bg-gradient-to-b from-green-500/5 to-transparent">
        <div class="flex items-center gap-3 mb-5">
          <div class="text-2xl font-bold">🤖 ChatGPT</div>
          <div class="text-xs text-green-400 font-mono">800M+ weekly · Bing + GPTBot</div>
        </div>
        <p class="text-xs text-muted mb-4">ChatGPT pulls from Bing's search index. We make sure your site is the answer it finds.</p>
        <ol class="space-y-3">
          {[
            { step: '01', label: 'Meta Description Optimization', desc: 'Every page gets a crisp, AI-readable description (50–160 chars) — the exact format ChatGPT extracts for direct answers.' },
            { step: '02', label: 'Structured Data / Schema Markup', desc: 'We deploy JSON-LD schema so ChatGPT understands what your business does, where it operates, and what it offers — without guessing.' },
            { step: '03', label: 'Direct-Answer Content', desc: 'We structure content so ChatGPT can pull clean answers from your pages — service definitions, location data, FAQs, pricing.' },
            { step: '04', label: 'GPTBot Crawl Access', desc: 'We verify GPTBot can crawl every page. No blocked paths, no missing content — ChatGPT can read your entire site.' },
            { step: '05', label: 'Open Graph & Social Signals', desc: 'OG tags ensure your content previews correctly when ChatGPT cites your business — driving clicks from AI recommendations.' },
          ].map((item) => (
            <li class="flex gap-3 text-sm">
              <span class="text-green-400 font-mono text-xs shrink-0 mt-0.5">{item.step}</span>
              <div>
                <div class="font-medium text-white text-sm">{item.label}</div>
                <div class="text-muted text-xs mt-0.5">{item.desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <!-- Claude -->
      <div class="gradient-border rounded-2xl p-6 md:p-8 bg-gradient-to-b from-orange-500/5 to-transparent">
        <div class="flex items-center gap-3 mb-5">
          <div class="text-2xl font-bold">🧠 Claude</div>
          <div class="text-xs text-orange-400 font-mono">Millions weekly · Brave + ClaudeBot</div>
        </div>
        <p class="text-xs text-muted mb-4">Claude prioritizes depth and authority. Short pages without backlinks are invisible here.</p>
        <ol class="space-y-3">
          {[
            { step: '01', label: 'Substantial Content Depth', desc: 'Claude favors pages with 800+ words of substantive content. We ensure every key page has the depth Claude looks for.' },
            { step: '02', label: 'Authoritative Backlink Building', desc: 'We monitor, audit, and grow your backlink profile — Claude ranks sources by citation count and domain authority.' },
            { step: '03', label: 'ClaudeBot Crawl Access', desc: 'We configure robots.txt and verify ClaudeBot can access and index every important page on your site.' },
            { step: '04', label: 'Open Graph Tags', desc: 'OG title, description, and image tags tell Claude exactly how to represent your business when it cites you.' },
            { step: '05', label: 'Citation Consistency', desc: 'We ensure your business name, address, and phone are consistent everywhere — Claude cross-references citations to verify authority.' },
          ].map((item) => (
            <li class="flex gap-3 text-sm">
              <span class="text-orange-400 font-mono text-xs shrink-0 mt-0.5">{item.step}</span>
              <div>
                <div class="font-medium text-white text-sm">{item.label}</div>
                <div class="text-muted text-xs mt-0.5">{item.desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <!-- Gemini -->
      <div class="gradient-border rounded-2xl p-6 md:p-8 bg-gradient-to-b from-blue-500/5 to-transparent">
        <div class="flex items-center gap-3 mb-5">
          <div class="text-2xl font-bold">🔍 Gemini</div>
          <div class="text-xs text-blue-400 font-mono">Integrated in Google · Knowledge Graph</div>
        </div>
        <p class="text-xs text-muted mb-4">Gemini is Google's AI. It pulls from Google Search and the Knowledge Graph — your Google presence IS your Gemini presence.</p>
        <ol class="space-y-3">
          {[
            { step: '01', label: 'Google Business Profile Optimization', desc: 'The #1 signal for Gemini. We optimize your GBP — categories, services, photos, reviews, posts — so Gemini surfaces you for local queries.' },
            { step: '02', label: 'Structured Data / Schema Markup', desc: 'Organization, LocalBusiness, and FAQ schema feed directly into Google\'s Knowledge Graph, which Gemini relies on.' },
            { step: '03', label: 'Page Speed & Mobile Optimization', desc: 'Gemini inherits Google\'s ranking signals. Fast-loading, mobile-friendly pages get priority in AI-generated answers.' },
            { step: '04', label: 'Title Tags & Meta Strategy', desc: 'Clean, keyword-aware title tags help Google — and therefore Gemini — understand what each page is about.' },
            { step: '05', label: 'Review & Reputation Monitoring', desc: 'Gemini surfaces businesses with strong review profiles. We track and help you build reviews across Google, Facebook, and industry platforms.' },
          ].map((item) => (
            <li class="flex gap-3 text-sm">
              <span class="text-blue-400 font-mono text-xs shrink-0 mt-0.5">{item.step}</span>
              <div>
                <div class="font-medium text-white text-sm">{item.label}</div>
                <div class="text-muted text-xs mt-0.5">{item.desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <!-- Perplexity -->
      <div class="gradient-border rounded-2xl p-6 md:p-8 bg-gradient-to-b from-purple-500/5 to-transparent">
        <div class="flex items-center gap-3 mb-5">
          <div class="text-2xl font-bold">⚡ Perplexity</div>
          <div class="text-xs text-purple-400 font-mono">Fastest growing · Proprietary + Google</div>
        </div>
        <p class="text-xs text-muted mb-4">Perplexity cites its sources inline. If your content is structured for citation, you show up — with a clickable link.</p>
        <ol class="space-y-3">
          {[
            { step: '01', label: 'FAQ & Direct-Answer Content', desc: 'Perplexity favors pages that directly answer questions. We build FAQ sections and Q&A content across your site.' },
            { step: '02', label: 'Structured Data for Source Citation', desc: 'Schema markup (FAQ, HowTo, Article) tells Perplexity your content is a citable source — with proper attribution.' },
            { step: '03', label: 'PerplexityBot Crawl Access', desc: 'We ensure PerplexityBot is allowed in robots.txt and can reach every page we want cited.' },
            { step: '04', label: 'Fresh Content Signals', desc: 'Perplexity rewards recently updated content. Weekly blog posts and regular site updates signal freshness to the engine.' },
            { step: '05', label: 'Clean, Crawlable Page Structure', desc: 'Well-structured headings, short paragraphs, and clear section labels make your content easy for Perplexity to extract and cite.' },
          ].map((item) => (
            <li class="flex gap-3 text-sm">
              <span class="text-purple-400 font-mono text-xs shrink-0 mt-0.5">{item.step}</span>
              <div>
                <div class="font-medium text-white text-sm">{item.label}</div>
                <div class="text-muted text-xs mt-0.5">{item.desc}</div>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- Why Businesses Are Moving Now -->
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-8">
        <h3 class="text-xl font-bold mb-2">Why Businesses Are Moving Now</h3>
        <p class="text-muted text-sm">Every month you wait, your competitors are getting cited by AI instead of you.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        {[
          { stat: '51%', desc: 'of B2B buyers start research in AI chatbots more than Google' },
          { stat: '69%', desc: 'chose a different vendor based on AI recommendations' },
          { stat: '99%', desc: 'of measurable AI referrals come from ChatGPT, Claude, Gemini & Perplexity' },
        ].map(item => (
          <div class="gradient-border rounded-xl p-6 text-center">
            <div class="text-3xl font-bold gradient-text mb-2">{item.stat}</div>
            <div class="text-xs text-muted leading-relaxed">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- How It Works -->
<section id="how-it-works" class="py-24 px-6 bg-surface/30">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <div class="text-sm text-cyan-300 font-mono mb-4">THE PROCESS</div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Three Steps to AI Visibility</h2>
      <p class="text-muted">No complicated onboarding. No endless meetings. Just your business showing up where it matters.</p>
    </div>

    <div class="space-y-8">
      {[
        { step: '01', title: 'Show Us Your Site', desc: 'Point your domain. We handle DNS, hosting, and initial site setup. Existing site? We\'ll migrate it — no downtime.' },
        { step: '02', title: 'We Activate the Engines', desc: 'Our system audits your AI visibility across all four platforms, identifies gaps, and begins optimizing — content, schema, citations, and bot access. First report within 24 hours.' },
        { step: '03', title: 'You Get Cited by AI', desc: 'Watch your business start appearing in ChatGPT, Claude, Gemini, and Perplexity answers. Monthly reports track every platform. Google rankings improve as a bonus.' },
      ].map((item) => (
        <div class="flex gap-6 items-start">
          <div class="text-4xl font-bold gradient-text font-mono shrink-0">{item.step}</div>
          <div>
            <h3 class="font-semibold text-xl mb-2">{item.title}</h3>
            <p class="text-muted">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Results -->
<section id="results" class="py-24 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="text-sm text-cyan-300 font-mono mb-4">THE RESULTS</div>
    <h2 class="text-3xl md:text-4xl font-bold mb-4">What Your Business Gets</h2>
    <p class="text-muted mb-16 max-w-xl mx-auto">
      AI visibility that traditional agencies can't deliver — at a fraction of the cost.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { value: '24h', label: 'First AI Visibility Report' },
        { value: '4', label: 'AI Engines Monitored' },
        { value: 'Weekly', label: 'Updates & Optimizations' },
        { value: '99.9%', label: 'Uptime Guaranteed' },
      ].map((stat) => (
        <div>
          <div class="text-3xl font-bold gradient-text mb-1">{stat.value}</div>
          <div class="text-sm text-muted">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Pricing -->
<section id="pricing" class="py-24 px-6 bg-surface/30">
  <div class="max-w-6xl mx-auto text-center">
    <div class="text-sm text-cyan-300 font-mono mb-4">PRICING</div>
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Get Found on AI — At a Price That Makes Sense.</h2>
    <p class="text-muted mb-16">Pick the plan that matches how fast you want to grow. Every plan month-to-month, cancel anytime.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- GEO/SEO Management -->
      <div class="gradient-border rounded-2xl p-8 md:p-10 text-left">
        <div class="text-sm text-purple-300 font-semibold mb-2">GEO/SEO MANAGEMENT</div>
        <div class="text-5xl font-bold mb-1">$599<span class="text-lg text-muted font-normal">/mo</span></div>
        <p class="text-muted text-sm mb-8">AI visibility monitoring, weekly SEO audits, keyword & competitor tracking — you handle the site.</p>

        <ul class="space-y-3 mb-8">
          {[
            'AI visibility monitoring (4 engines)',
            'Weekly SEO audits (100+ checks)',
            'Keyword & competitor tracking',
            'Backlink profile monitoring',
            'Content strategy & calendar',
            'Technical SEO & schema markup',
            'Internal link optimization',
            'Conversion-focused recommendations',
            'Core Web Vitals monitoring',
            'Monthly AI & search ranking reports',
            'Priority email support',
          ].map((feature) => (
            <li class="flex items-center gap-3 text-sm">
              <span class="text-green-400 shrink-0">✓</span> {feature}
            </li>
          ))}
        </ul>

        <a href="/signup?plan=seo_management" class="btn-primary block text-center w-full">Get Started</a>
      </div>

      <!-- Full Management -->
      <div class="gradient-border rounded-2xl p-8 md:p-10 text-left relative bg-purple-500/[0.03]">
        <div class="absolute -top-3 right-6 text-xs px-3 py-1 bg-purple-500/20 border border-purple-500/40 rounded-full text-purple-300 font-semibold">MOST POPULAR</div>
        <div class="text-sm text-cyan-300 font-semibold mb-2">FULL MANAGEMENT</div>
        <div class="text-5xl font-bold mb-1">$999<span class="text-lg text-muted font-normal">/mo</span></div>
        <p class="text-muted text-sm mb-4">Full AI optimization + we build, host, and maintain your site. Hands-free visibility on every platform.</p>
        <p class="text-xs text-muted mb-8 pb-6 border-b border-white/5">+ one-time site build or <span class="text-white font-medium">$1,000 migration</span> for existing sites</p>

        <ul class="space-y-3 mb-8">
          {[
            'Everything in GEO/SEO Management',
            'Full AI optimization — ChatGPT, Claude, Gemini, Perplexity',
            'Citation & mention building',
            'Weekly blog content (researched & written)',
            'Full site hosting on global edge network',
            'Unlimited site edits & updates',
            'Easy content approval workflow',
            'Google Business Profile optimization',
            'Business listing management',
            'Service-area landing pages',
            'Local SEO & citation strategy',
            'Dedicated support',
          ].map((feature) => (
            <li class="flex items-center gap-3 text-sm">
              <span class="text-green-400 shrink-0">✓</span> {feature}
            </li>
          ))}
        </ul>

        <a href="/signup?plan=full_management" class="btn-primary block text-center w-full">Get Full Management</a>
      </div>
    </div>

    <!-- Site Builds -->
    <div class="mt-16 max-w-lg mx-auto">
      <div class="text-sm text-cyan-300 font-mono mb-2">ONE-TIME</div>
      <h3 class="text-xl font-bold mb-2">Site Builds & Migration</h3>
      <p class="text-muted text-sm mb-6">Custom sites on a global edge network. Or bring your existing site — we'll migrate it seamlessly.</p>
      <div class="space-y-3 text-left">
        {[
          { pages: 'Landing Page', price: '$1,250', desc: 'Single-page site. Perfect for product launches or lead gen.' },
          { pages: 'Up to 5 Pages', price: '$2,500', desc: 'Home, About, Services, Blog, Contact — the full stack.' },
          { pages: 'Site Migration', price: '$1,000', desc: 'Moving from Wix, Squarespace, WordPress? We handle DNS, content, and redirects without downtime.' },
          { pages: '6+ Pages', price: 'Custom', desc: 'Complex sites, e-commerce, dashboards. Let\'s talk.' },
        ].map((tier) => (
          <div class="flex items-center justify-between gradient-border rounded-xl p-4">
            <div>
              <div class="font-semibold text-sm">{tier.pages}</div>
              <div class="text-xs text-muted">{tier.desc}</div>
            </div>
            <div class="text-lg font-bold gradient-text shrink-0 ml-4">{tier.price}</div>
          </div>
        ))}
      </div>
      <a href="/contact" class="btn-secondary inline-block mt-8">Tell Us What You Need →</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-24 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Show Up When It Matters?</h2>
    <p class="text-muted mb-8">
      Get a free report on how your business currently appears across ChatGPT, Claude, Perplexity, 
      and Gemini — and what it'll take to get you cited, recommended, and visible in every AI answer.
    </p>
    <a href="/contact" class="btn-primary text-lg">Get My Free AI Visibility Report →</a>
  </div>
</section>

</Layout>
