---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- Hero -->
<section class="relative pt-32 pb-20 px-6 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-purple-500/5 via-transparent to-transparent"></div>
  <div class="absolute top-20 left-1/2 -translate-x-1/2 w-[600px] h-[600px] bg-purple-500/10 rounded-full blur-3xl"></div>

  <div class="max-w-4xl mx-auto text-center relative">
    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border border-cyan-500/20 bg-cyan-500/5 text-sm text-cyan-300 mb-8">
      <span class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse"></span>
      The Secret Formula for SEO — Now in Beta
    </div>

    <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold tracking-tight leading-none mb-6">
      We Have the<br/>
      <span class="gradient-text">Secret Formula</span>
    </h1>

    <p class="text-lg md:text-xl text-muted max-w-2xl mx-auto mb-10">
      Rank Labs is the AI-operated SEO platform that builds, manages, and optimizes
      your entire web presence — like having a mad scientist running your search strategy,
      minus the lab coat.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="/contact" class="btn-primary text-lg">Get the Formula →</a>
      <a href="/#how-it-works" class="btn-secondary text-lg">See How It Works</a>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 mt-20 pt-12 border-t border-white/5">
      <div>
        <div class="text-3xl font-bold gradient-text">Weekly</div>
        <div class="text-sm text-muted mt-1">Automated SEO Audits</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">100%</div>
        <div class="text-sm text-muted mt-1">AI Content Pipeline</div>
      </div>
      <div>
        <div class="text-3xl font-bold gradient-text">From $599</div>
        <div class="text-sm text-muted mt-1">Per Month</div>
      </div>
    </div>
  </div>
</section>

<!-- Formula Ingredients -->
<section id="services" class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <div class="text-sm text-cyan-300 font-mono mb-4">THE FORMULA</div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Every Breakthrough Starts in the Lab</h2>
      <p class="text-muted max-w-xl mx-auto">Six ingredients. One platform. Zero overhead.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {[
        {
          icon: '🧪',
          title: 'Weekly SEO Audits',
          desc: 'Our AI crawls your site every week like a lab assistant on caffeine — surfacing broken links, missing meta, slow pages, and ranking opportunities.',
        },
        {
          icon: '⚗️',
          title: 'Automated Blog Content',
          desc: 'AI researches your niche, formulates 800+ word posts, and sends them for your one-click approval. Fresh content, every week.',
        },
        {
          icon: '🔬',
          title: 'Full Site Management',
          desc: 'We build, host, and maintain your site on Cloudflare\'s global edge. Blazing fast, always online, fully managed.',
        },
        {
          icon: '📊',
          title: 'Ranking Reports',
          desc: 'Clear, visual reports on your keyword positions, traffic trends, and competitor gaps. The data, distilled.',
        },
        {
          icon: '🧬',
          title: 'AI Content Pipeline',
          desc: 'From keyword research to published post — our AI pipeline handles ideation, writing, optimization, and scheduling.',
        },
        {
          icon: '✅',
          title: 'Approval Workflow',
          desc: 'You\'re the head scientist. Review and approve every piece of content before it goes live. One click.',
        },
      ].map((service) => (
        <div class="gradient-border rounded-xl p-6 hover:bg-surface-light/50 transition-colors">
          <div class="text-3xl mb-4">{service.icon}</div>
          <h3 class="font-semibold text-lg mb-2">{service.title}</h3>
          <p class="text-sm text-muted leading-relaxed">{service.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- How It Works -->
<section id="how-it-works" class="py-24 px-6 bg-surface/30">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-16">
      <div class="text-sm text-cyan-300 font-mono mb-4">THE PROCESS</div>
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Three Steps to Search Dominance</h2>
      <p class="text-muted">No complicated onboarding. No endless meetings. Just results.</p>
    </div>

    <div class="space-y-8">
      {[
        { step: '01', title: 'Connect Your Site', desc: 'Point your domain. We handle DNS, hosting on Cloudflare Pages, and initial site setup. Existing site? We\'ll migrate it — no downtime.' },
        { step: '02', title: 'The Formula Activates', desc: 'Our AI begins weekly crawls, content research, and optimization. Your first audit arrives within 24 hours. No meetings, no calls, no waiting.' },
        { step: '03', title: 'Review & Approve', desc: 'Content drafts land in your inbox. One-click approve or request changes. Audits and reports arrive weekly — you\'re always in control.' },
      ].map((item) => (
        <div class="flex gap-6 items-start">
          <div class="text-4xl font-bold gradient-text font-mono shrink-0">{item.step}</div>
          <div>
            <h3 class="font-semibold text-xl mb-2">{item.title}</h3>
            <p class="text-muted">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Results -->
<section id="results" class="py-24 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="text-sm text-cyan-300 font-mono mb-4">THE RESULTS</div>
    <h2 class="text-3xl md:text-4xl font-bold mb-4">What the Formula Produces</h2>
    <p class="text-muted mb-16 max-w-xl mx-auto">
      AI-driven SEO that traditional agencies can't match — at a fraction of the cost.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {[
        { value: '24h', label: 'First Audit Delivered' },
        { value: '100+', label: 'SEO Checks Per Audit' },
        { value: 'Weekly', label: 'Fresh Content Drafts' },
        { value: '99.9%', label: 'Uptime on Cloudflare' },
      ].map((stat) => (
        <div>
          <div class="text-3xl font-bold gradient-text mb-1">{stat.value}</div>
          <div class="text-sm text-muted">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Pricing -->
<section id="pricing" class="py-24 px-6 bg-surface/30">
  <div class="max-w-6xl mx-auto text-center">
    <div class="text-sm text-cyan-300 font-mono mb-4">THE DEAL</div>
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Two Formulas. No Fluff.</h2>
    <p class="text-muted mb-16">Pick the level that fits. Every plan is month-to-month, cancel anytime.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
      <!-- SEO Management -->
      <div class="gradient-border rounded-2xl p-8 md:p-10 text-left">
        <div class="text-sm text-purple-300 font-semibold mb-2">SEO MANAGEMENT</div>
        <div class="text-5xl font-bold mb-1">$599<span class="text-lg text-muted font-normal">/mo</span></div>
        <p class="text-muted text-sm mb-8">Weekly audits, rankings, and strategy — you handle the site.</p>

        <ul class="space-y-3 mb-8">
          {[
            'Weekly automated SEO audits',
            'Keyword & competitor tracking',
            'Monthly ranking reports',
            'Content strategy recommendations',
            'Technical SEO issue detection',
            'Priority email support',
          ].map((feature) => (
            <li class="flex items-center gap-3 text-sm">
              <span class="text-green-400 shrink-0">✓</span> {feature}
            </li>
          ))}
        </ul>

        <a href="https://buy.stripe.com/test_eVq9AT3AQdTvbaI3QX1gs00" class="btn-secondary block text-center w-full">Get Started</a>
      </div>

      <!-- Full Management -->
      <div class="gradient-border rounded-2xl p-8 md:p-10 text-left relative bg-purple-500/[0.03]">
        <div class="absolute -top-3 right-6 text-xs px-3 py-1 bg-purple-500/20 border border-purple-500/40 rounded-full text-purple-300 font-semibold">MOST POPULAR</div>
        <div class="text-sm text-cyan-300 font-semibold mb-2">FULL MANAGEMENT</div>
        <div class="text-5xl font-bold mb-1">$999<span class="text-lg text-muted font-normal">/mo</span></div>
        <p class="text-muted text-sm mb-4">Everything in SEO + we build, host, and maintain your site. Hands-free.</p>
        <p class="text-xs text-muted mb-8 pb-6 border-b border-white/5">+ one-time site build or <span class="text-white font-medium">$1,000 migration</span> for existing sites</p>

        <ul class="space-y-3 mb-8">
          {[
            'Everything in SEO Management',
            'AI blog content (2 posts/week)',
            'Full site hosting on Cloudflare',
            'Site edits, updates & maintenance',
            'One-click content approval',
            'Dedicated Telegram support',
          ].map((feature) => (
            <li class="flex items-center gap-3 text-sm">
              <span class="text-green-400 shrink-0">✓</span> {feature}
            </li>
          ))}
        </ul>

        <a href="https://buy.stripe.com/test_fZu6oH8Va8zbfqYfzF1gs01" class="btn-primary block text-center w-full">Get the Formula</a>
      </div>
    </div>

    <!-- Site Builds -->
    <div class="mt-16 max-w-lg mx-auto">
      <div class="text-sm text-cyan-300 font-mono mb-2">ONE-TIME</div>
      <h3 class="text-xl font-bold mb-2">Site Builds & Migration</h3>
      <p class="text-muted text-sm mb-6">Custom sites on Cloudflare's global edge. Or bring your existing site — we'll migrate it seamlessly.</p>
      <div class="space-y-3 text-left">
        {[
          { pages: 'Landing Page', price: '$1,250', desc: 'Single-page site. Perfect for product launches or lead gen.' },
          { pages: 'Up to 5 Pages', price: '$2,500', desc: 'Home, About, Services, Blog, Contact — the full stack.' },
          { pages: 'Site Migration', price: '$1,000', desc: 'Moving from Wix, Squarespace, WordPress? We handle DNS, content, and redirects without downtime.' },
          { pages: '6+ Pages', price: 'Custom', desc: 'Complex sites, e-commerce, dashboards. Let\'s talk.' },
        ].map((tier) => (
          <div class="flex items-center justify-between gradient-border rounded-xl p-4">
            <div>
              <div class="font-semibold text-sm">{tier.pages}</div>
              <div class="text-xs text-muted">{tier.desc}</div>
            </div>
            <div class="text-lg font-bold gradient-text shrink-0 ml-4">{tier.price}</div>
          </div>
        ))}
      </div>
      <a href="/contact" class="btn-secondary inline-block mt-8">Tell Us What You Need →</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="py-24 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Crack the Code?</h2>
    <p class="text-muted mb-8">
      Get your free SEO audit and discover what the formula can do for your site. No obligation, no sales pitch.
    </p>
    <a href="/contact" class="btn-primary text-lg">Get Your Free Audit →</a>
  </div>
</section>

</Layout>
